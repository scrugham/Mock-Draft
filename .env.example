# NFL draft year ESPN uses for the API (set to 2026 for this year’s draft).
DRAFT_SEASON=2026

# Set to true to ignore ESPN and read picks from public/manual-draft.json
# (or the file named in DRAFT_MANUAL_FILE). Useful if ESPN is down or blocked.
USE_MANUAL_DRAFT=false

# Filename under /public when USE_MANUAL_DRAFT=true
DRAFT_MANUAL_FILE=manual-draft.json
